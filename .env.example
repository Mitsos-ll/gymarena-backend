# ── Copier en .env et remplir les valeurs ────────────────────────────────────
# Le fichier .env n'est JAMAIS commité (voir .gitignore)

# Obligatoire — Google OAuth Web Client ID
GOOGLE_WEB_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Serveur
PORT=3000
ENV=development          # development | production

# Base de données SQLite
DATABASE_PATH=data/gymtrack.db

# Tokens (en jours)
ACCESS_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_TTL_DAYS=90

# CORS — origines autorisées, séparées par virgule (* = tout autoriser en dev)
CORS_ALLOWED_ORIGINS=*

# Rate limiting — requêtes max par IP par fenêtre glissante
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Auth endpoints rate limiting (plus strict)
AUTH_RATE_LIMIT_MAX_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Admin — clé secrète pour GET /admin/stats (génère avec: openssl rand -hex 32)
ADMIN_SECRET=change-me-generate-a-strong-secret
